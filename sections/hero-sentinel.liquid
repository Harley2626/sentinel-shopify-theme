{{ 'hero-sentinel.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_video = false
  if section.settings.background_video != blank
    assign has_video = true
  endif

  assign has_image = false
  if section.settings.background_image != blank
    assign has_image = true
  endif

  assign has_media = false
  if has_video or has_image
    assign has_media = true
  endif

  assign has_helmet = false
  if section.settings.helmet_image != blank
    assign has_helmet = true
  endif

  assign hero_classes = 'hero-sentinel full-width'
  if has_media
    assign hero_classes = hero_classes | append: ' hero-sentinel--has-media'
  endif

  assign align_class = 'hero-sentinel--align-' | append: section.settings.text_alignment
  assign hero_classes = hero_classes | append: ' ' | append: align_class

  assign helmet_alt = section.settings.helmet_image.alt
  if helmet_alt == blank
    assign helmet_alt = 'Sentinel Cricket Helmet'
  endif
-%}

{% style %}
  #HeroSentinel-{{ section.id }} {
    --hero-height-mobile: {{ section.settings.mobile_height }}vh;
    --hero-height-desktop: {{ section.settings.desktop_height }}vh;
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
{% endstyle %}

<section
  id="HeroSentinel-{{ section.id }}"
  class="{{ hero_classes }}"
  data-hero-sentinel
  aria-label="{{ section.settings.heading | default: 'Hero' | escape }}"
>
  <div class="hero-sentinel__atmosphere" aria-hidden="true">
    <div class="hero-sentinel__gradient"></div>
    <div class="hero-sentinel__glow"></div>
    <div class="hero-sentinel__grid-texture"></div>
    <div class="hero-sentinel__noise"></div>
    <div class="hero-sentinel__vignette"></div>
  </div>

  {%- if has_media -%}
    <div class="hero-sentinel__media" aria-hidden="true">
      <div class="hero-sentinel__media-inner" data-motion-parallax-inner>
        {%- if has_video -%}
          {{
            section.settings.background_video
            | video_tag:
              class: 'hero-sentinel__video',
              autoplay: true,
              loop: true,
              muted: true,
              controls: false,
              playsinline: true,
              preload: 'auto',
              image_size: '1920x'
          }}
        {%- else -%}
          {{
            section.settings.background_image
            | image_url: width: 2400
            | image_tag:
              class: 'hero-sentinel__image',
              loading: 'eager',
              fetchpriority: 'high',
              widths: '750, 1100, 1500, 1920, 2400',
              sizes: '100vw',
              alt: ''
          }}
        {%- endif -%}
      </div>
    </div>
    <div class="hero-sentinel__overlay" aria-hidden="true"></div>
  {%- endif -%}

  <div class="hero-sentinel__container hero-sentinel__container--wide">
    <div class="hero-sentinel__grid">
      <div class="hero-sentinel__content" data-motion-immediate>
        {%- if section.settings.eyebrow != blank -%}
          <p class="sentinel-caption hero-sentinel__eyebrow" data-motion-reveal data-motion-index="1">
            {{ section.settings.eyebrow | escape }}
          </p>
        {%- endif -%}

        <span class="hero-sentinel__accent" data-motion-reveal data-motion-index="2" aria-hidden="true"></span>

        {%- if section.settings.heading != blank -%}
          {%- assign heading_lines = section.settings.heading | split: '
' -%}
          <h1 class="sentinel-heading hero-sentinel__heading">
            {%- for line in heading_lines -%}
              {%- assign clean_line = line | strip -%}
              {%- if clean_line != blank -%}
                {%- assign line_index = forloop.index | plus: 2 -%}
                <span class="hero-sentinel__heading-line" data-motion-reveal data-motion-index="{{ line_index }}">{{ clean_line | escape }}</span>
              {%- endif -%}
            {%- endfor -%}
          </h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="hero-sentinel__subheading" data-motion-reveal data-motion-index="6">
            {{ section.settings.subheading | escape }}
          </p>
        {%- endif -%}

        {%- if section.settings.primary_button != blank or section.settings.secondary_button != blank -%}
          <div class="hero-sentinel__actions" data-motion-reveal data-motion-index="7">
            {%- if section.settings.primary_button != blank -%}
              {% render 'sentinel-button',
                label: section.settings.primary_button,
                url: section.settings.primary_url,
                variant: 'primary',
                size: 'lg'
              %}
            {%- endif -%}

            {%- if section.settings.secondary_button != blank -%}
              {% render 'sentinel-button',
                label: section.settings.secondary_button,
                url: section.settings.secondary_url,
                variant: 'secondary',
                size: 'lg'
              %}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <div class="hero-sentinel__visual" data-motion-float="hero">
        <div class="hero-sentinel__product-stage" data-hero-product data-motion-parallax data-motion-parallax-max="10">
          <div class="hero-sentinel__product-glow" data-motion-glow aria-hidden="true"></div>
          {%- if has_helmet -%}
            {{
              section.settings.helmet_image
              | image_url: width: 1200
              | image_tag:
                class: 'hero-sentinel__helmet',
                loading: 'eager',
                fetchpriority: 'high',
                widths: '600, 800, 1000, 1200',
                sizes: '(min-width: 990px) 42rem, (min-width: 750px) 34rem, 78vw',
                alt: helmet_alt
            }}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {%- if section.settings.show_scroll_indicator -%}
    <a class="hero-sentinel__scroll" href="#MainContent" data-hero-scroll data-motion-reveal data-motion-index="8" aria-label="{{ 'sections.hero_sentinel.scroll' | t }}">
      <span class="hero-sentinel__scroll-icon" aria-hidden="true"></span>
      <span class="hero-sentinel__scroll-label">{{ 'sections.hero_sentinel.scroll' | t }}</span>
    </a>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "t:sections.hero_sentinel.name",
  "tag": "section",
  "class": "hero-sentinel-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.hero_sentinel.settings.media_header"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.hero_sentinel.settings.background_image",
      "info": "t:sections.hero_sentinel.settings.background_image_info"
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "t:sections.hero_sentinel.settings.background_video",
      "info": "t:sections.hero_sentinel.settings.background_video_info"
    },
    {
      "type": "image_picker",
      "id": "helmet_image",
      "label": "t:sections.hero_sentinel.settings.helmet_image",
      "info": "t:sections.hero_sentinel.settings.helmet_image_info"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.hero_sentinel.settings.overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 85,
      "info": "t:sections.hero_sentinel.settings.overlay_opacity_info"
    },
    {
      "type": "header",
      "content": "t:sections.hero_sentinel.settings.content_header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.hero_sentinel.settings.eyebrow",
      "default": "Engineered performance"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "t:sections.hero_sentinel.settings.heading",
      "default": "Built for the crease"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.hero_sentinel.settings.subheading",
      "default": "Ultra-lightweight cricket helmets engineered with titanium protection, multi-density impact technology and uncompromising comfort for every innings."
    },
    {
      "type": "header",
      "content": "t:sections.hero_sentinel.settings.buttons_header"
    },
    {
      "type": "text",
      "id": "primary_button",
      "label": "t:sections.hero_sentinel.settings.primary_button",
      "default": "Shop collection"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "t:sections.hero_sentinel.settings.primary_url"
    },
    {
      "type": "text",
      "id": "secondary_button",
      "label": "t:sections.hero_sentinel.settings.secondary_button",
      "default": "Explore Technology"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "t:sections.hero_sentinel.settings.secondary_url"
    },
    {
      "type": "header",
      "content": "t:sections.hero_sentinel.settings.layout_header"
    },
    {
      "type": "text_alignment",
      "id": "text_alignment",
      "label": "t:sections.hero_sentinel.settings.text_alignment",
      "default": "left"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "t:sections.hero_sentinel.settings.desktop_height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 100
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "t:sections.hero_sentinel.settings.mobile_height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "t:sections.hero_sentinel.settings.show_scroll_indicator",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero_sentinel.name",
      "category": "t:sections.hero_sentinel.category"
    }
  ]
}
{% endschema %}
