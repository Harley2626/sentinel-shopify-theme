{% doc %}
  Premium product gallery with hero image and thumbnail selector.

  @param {product} product - The product object

  @example
  {% render 'product-sentinel-gallery', product: product %}
{% enddoc %}

{%- liquid
  if product.media.size > 0
    assign gallery_items = product.media
    assign use_product_media = true
  elsif product.images.size > 0
    assign gallery_items = product.images
    assign use_product_media = false
  else
    assign gallery_items = null
  endif

  assign featured_item = product.selected_or_first_available_variant.featured_media
  if featured_item == blank
    assign featured_item = product.featured_media
  endif
  if featured_item == blank and gallery_items != null
    assign featured_item = gallery_items.first
  endif
-%}

<div class="product-sentinel-gallery" data-product-gallery>
  <div class="product-sentinel-gallery__hero">
    {%- if featured_item != blank -%}
      {{
        featured_item
        | image_url: width: 1200
        | image_tag:
          class: 'product-sentinel-gallery__hero-image',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '400, 600, 800, 1000, 1200',
          sizes: '(min-width: 990px) 50vw, 100vw',
          alt: featured_item.alt | default: product.title,
          data-gallery-hero: ''
      }}
    {%- else -%}
      <div class="product-sentinel-gallery__placeholder sentinel-bg-surface" data-gallery-hero aria-hidden="true"></div>
    {%- endif -%}
  </div>

  {%- if gallery_items != null and gallery_items.size > 1 -%}
    <div class="product-sentinel-gallery__thumbs" role="list" aria-label="{{ 'products.gallery.thumbnails' | t }}">
      {%- for item in gallery_items -%}
        {%- liquid
          assign thumb_active = false
          if use_product_media
            if item.id == featured_item.id
              assign thumb_active = true
            endif
            assign thumb_key = item.id
          else
            if item == featured_item
              assign thumb_active = true
            endif
            assign thumb_key = forloop.index
          endif
        -%}
        <button
          type="button"
          class="product-sentinel-gallery__thumb{% if thumb_active %} product-sentinel-gallery__thumb--active{% endif %}"
          data-gallery-thumb
          data-thumb-key="{{ thumb_key }}"
          data-image-src="{{ item | image_url: width: 1200 }}"
          data-image-alt="{{ item.alt | default: product.title | escape }}"
          aria-label="{{ 'products.gallery.view_image' | t: index: forloop.index }}"
          aria-pressed="{{ thumb_active }}"
          role="listitem"
        >
          {{
            item
            | image_url: width: 160
            | image_tag:
              class: 'product-sentinel-gallery__thumb-image',
              loading: 'lazy',
              widths: '80, 120, 160',
              sizes: '80px',
              alt: ''
          }}
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
