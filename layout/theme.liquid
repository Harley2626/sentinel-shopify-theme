<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Legacy skeleton CSS variables (Dawn/Skeleton bridge) %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Sentinel design system %}
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {% render 'sentinel-design-system' %}

    {% # Sentinel favicon %}
    {% render 'sentinel-favicon' %}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body class="sentinel-theme">
    {% sections 'header-group' %}

    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    <script src="{{ 'sentinel-motion.js' | asset_url }}" defer></script>
  </body>
</html>
