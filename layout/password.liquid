<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Legacy skeleton CSS variables (Dawn/Skeleton bridge) %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Sentinel design system %}
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {% render 'sentinel-design-system' %}

    {% render 'sentinel-favicon' %}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body class="sentinel-theme">
    {{ content_for_layout }}
  </body>
</html>
